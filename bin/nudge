#!/usr/bin/env bash
#
# nudge — core CLI for tmux-nudge.
#
# Marks a pane as "needing a human" and renders a layered attention signal:
#   Layer A  per-pane border colour pulse   (driven explicitly by the daemon)
#   Layer B  per-pane border label line     (declarative, via pane-border-format)
# A pane is cleared automatically when you focus it.
#
# Commands:
#   nudge init                       install global formats + hooks (idempotent)
#   nudge on   [-t pane] [-s state]  mark a pane (state: needs-input|done|error)
#   nudge off  [-t pane]             clear a pane
#   nudge daemon [-i seconds]        the pulse loop (singleton; auto-exits when idle)
#   nudge status                     list currently-nudging panes
#
set -euo pipefail

# Talk to a specific server if NUDGE_SOCKET is set (handy for isolated testing);
# otherwise use the default server.
tmux() {
  if [ -n "${NUDGE_SOCKET:-}" ]; then command tmux -L "$NUDGE_SOCKET" "$@"
  else command tmux "$@"; fi
}

# Resolve absolute path to this script so hooks/daemon can re-invoke it.
SELF="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"

# Read a global tmux user option, falling back to a default. Lets users
# customise every colour/label/timing via `set -g @nudge-… …` in tmux.conf.
opt() {
  local v; v="$(tmux show -gv "$1" 2>/dev/null || true)"
  [ -n "$v" ] && echo "$v" || echo "$2"
}

# The "off" phase colour of the blink. Configurable so it contrasts with your
# background (otherwise the blink can be invisible).
DIM="$(opt @nudge-dim "${NUDGE_DIM:-colour238}")"

color_for_state() {
  case "$1" in
    needs-input) opt @nudge-color-needs-input "${NUDGE_COLOR_NEEDS_INPUT:-colour214}" ;;  # orange
    done)        opt @nudge-color-done        "${NUDGE_COLOR_DONE:-colour46}" ;;          # green
    error)       opt @nudge-color-error       "${NUDGE_COLOR_ERROR:-colour196}" ;;        # red
    *)           opt @nudge-color-needs-input colour214 ;;
  esac
}

label_for_state() {
  case "$1" in
    needs-input) opt @nudge-label-needs-input "● tmux-nudge — needs you" ;;
    done)        opt @nudge-label-done        "✓ tmux-nudge — done" ;;
    error)       opt @nudge-label-error       "✗ tmux-nudge — error" ;;
    *)           opt @nudge-label-needs-input "● tmux-nudge" ;;
  esac
}

# Whether to also blink the window's status-bar entry (per-pane label always shows).
window_blink_enabled() { [ "$(opt @nudge-window-blink on)" != off ]; }

# The daemon's pid is tracked in a tmux server option (not a $TMPDIR file, whose
# path varies between contexts) so ensure_daemon reliably finds a live daemon.
daemon_pid() { tmux show -gv @nudge_daemon_pid 2>/dev/null || true; }

active_count() {
  tmux list-panes -a -F '#{@nudge_state}' 2>/dev/null | grep -c . || true
}

# ---- commands -------------------------------------------------------------

cmd_init() {
  tmux set -g @nudge_phase 0

  # Save the user's original pane-border-format ONCE so non-nudging panes keep
  # their look (composed via #{E:} below) and it can be restored on uninstall.
  if [ -z "$(tmux show -gv @nudge_saved_pbf 2>/dev/null || true)" ]; then
    local orig; orig="$(tmux show -gv pane-border-format 2>/dev/null || true)"
    [ -n "$orig" ] || orig='#{pane_index} "#{pane_title}"'
    tmux set -g @nudge_saved_pbf "$orig"
  fi

  # Layer B: per-pane border label. Declarative — recomputes on every redraw,
  # so the daemon only needs to flip @nudge_phase to animate it. Non-nudging
  # panes fall back to the user's saved format (re-expanded via #{E:}).
  local fmt
  fmt='#{?#{@nudge_state},'
  fmt+='#{?#{==:#{@nudge_phase},1},#[fg=#{@nudge_color}]#[bold]#{@nudge_label},#[fg='"$DIM"']#{@nudge_label}}'
  fmt+=',#{E:@nudge_saved_pbf}}'
  tmux set -g pane-border-format "$fmt"

  # Note: auto-clear is handled by the daemon (it clears any nudging pane you're
  # actually viewing), not by select-pane hooks — that also works for mouse
  # clicks, which don't reliably fire those hooks.
}

cmd_on() {
  local pane="" state="needs-input" if_away=0
  while [ $# -gt 0 ]; do
    case "$1" in
      -t) pane="$2"; shift 2 ;;
      -s|--state) state="$2"; shift 2 ;;
      --if-away) if_away=1; shift ;;
      *) shift ;;
    esac
  done
  [ -n "$pane" ] || pane="$(tmux display-message -p '#{pane_id}')"

  # --if-away: skip if the pane is currently on-screen (active pane of the
  # current window of an attached session) — don't nag a pane you're watching.
  if [ "$if_away" = 1 ]; then
    local viewed
    viewed="$(tmux display-message -p -t "$pane" \
      '#{&&:#{&&:#{pane_active},#{window_active}},#{session_attached}}' 2>/dev/null || echo 0)"
    [ "$viewed" = 1 ] && return 0
  fi

  tmux set -p -t "$pane" @nudge_state "$state"
  tmux set -p -t "$pane" @nudge_color "$(color_for_state "$state")"
  tmux set -p -t "$pane" @nudge_label "$(label_for_state "$state")"

  # Layer B needs the border label line visible on this pane's window.
  local win; win="$(tmux display-message -p -t "$pane" '#{window_id}')"
  tmux set -w -t "$win" pane-border-status top

  # Layer C: blink the window's entry in the status list, but ONLY for the
  # inactive-window style — if you're already on this window, its label
  # shouldn't blink (the pane's own label covers that). Opt-out via
  # @nudge-window-blink off.
  if window_blink_enabled; then
    local wstyle="fg=$(color_for_state "$state"),bold"
    tmux set -w -t "$win" window-status-style "$wstyle" 2>/dev/null || true
  fi

  ensure_daemon
  tmux refresh-client 2>/dev/null || true
}

cmd_off() {
  local pane=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -t) pane="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  [ -n "$pane" ] || pane="$(tmux display-message -p '#{pane_id}')"

  # Clear state on this pane. (window-style/active-style are unset defensively
  # in case an older version left a background tint.)
  tmux set -pu -t "$pane" @nudge_state 2>/dev/null || true
  tmux set -pu -t "$pane" @nudge_color 2>/dev/null || true
  tmux set -pu -t "$pane" @nudge_label 2>/dev/null || true
  tmux set -pu -t "$pane" window-style 2>/dev/null || true
  tmux set -pu -t "$pane" window-active-style 2>/dev/null || true

  # If nothing else in the window is nudging, reclaim the label row (Layer B)
  # and restore the window's status-list style (Layer C).
  local win still
  win="$(tmux display-message -p -t "$pane" '#{window_id}' 2>/dev/null || true)"
  if [ -n "$win" ]; then
    still="$(tmux list-panes -t "$win" -F '#{@nudge_state}' 2>/dev/null | grep -c . || true)"
    if [ "${still:-0}" -eq 0 ]; then
      tmux set -wu -t "$win" pane-border-status 2>/dev/null || true
      tmux set -wu -t "$win" window-status-style 2>/dev/null || true
      tmux set -wu -t "$win" window-status-current-style 2>/dev/null || true
    fi
  fi
  tmux refresh-client 2>/dev/null || true
}

cmd_daemon() {
  # Blink speed (seconds per phase). Configurable via @nudge-interval.
  local interval; interval="$(opt @nudge-interval "${NUDGE_INTERVAL:-0.5}")"
  while [ $# -gt 0 ]; do case "$1" in -i) interval="$2"; shift 2 ;; *) shift ;; esac; done

  # If another live daemon already owns the slot, don't run a duplicate.
  local existing; existing="$(daemon_pid)"
  if [ -n "$existing" ] && [ "$existing" != "$$" ] && kill -0 "$existing" 2>/dev/null; then
    exit 0
  fi
  tmux set -g @nudge_daemon_pid "$$" 2>/dev/null || true
  trap 'tmux set -gu @nudge_daemon_pid 2>/dev/null || true' EXIT

  local phase=0 win state color style pid
  while :; do
    [ "$(active_count)" -eq 0 ] && break        # nothing to animate → exit
    phase=$((1 - phase))

    # Auto-clear any nudging pane you're now viewing: active pane of the current
    # window of an attached session. Works for mouse clicks, keyboard selection,
    # and window switches alike (no select-pane hooks needed).
    while read -r pid; do
      [ -n "$pid" ] && cmd_off -t "$pid"
    done < <(tmux list-panes -a -F \
      '#{?#{@nudge_state},#{?#{&&:#{&&:#{pane_active},#{window_active}},#{session_attached}},#{pane_id},},}' \
      2>/dev/null | grep -v '^$' || true)

    # Pulse Layer C (the window-list entry) per window that has a nudging pane,
    # unless disabled. The label (Layer B) blinks declaratively via @nudge_phase
    # below. Shared pane borders are left alone.
    if window_blink_enabled; then
      while read -r win state color; do
        [ -n "${state:-}" ] || continue
        if [ "$phase" = 1 ]; then style="fg=${color},bold"; else style="fg=${DIM}"; fi
        # Inactive-window style only — the active window's label is left alone.
        tmux set -w -t "$win" window-status-style "$style" 2>/dev/null || true
      done < <(tmux list-panes -a -F '#{window_id} #{@nudge_state} #{@nudge_color}' 2>/dev/null)
    fi

    # Layer B: one flag flip animates every label declaratively.
    tmux set -g @nudge_phase "$phase" 2>/dev/null || break

    # Force a redraw on every attached client.
    while read -r client; do
      [ -n "$client" ] && tmux refresh-client -t "$client" 2>/dev/null || true
    done < <(tmux list-clients -F '#{client_name}' 2>/dev/null)

    sleep "$interval"
  done
}

ensure_daemon() {
  local pid; pid="$(daemon_pid)"
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null && return 0
  nohup "$SELF" daemon >/dev/null 2>&1 &
  disown 2>/dev/null || true
}

cmd_status() {
  tmux list-panes -a -F '#{session_name}:#{window_index}.#{pane_index} [#{pane_id}] #{@nudge_state}' 2>/dev/null \
    | grep -E ' (needs-input|done|error|running)$' || echo "no active nudges"
}

# Fully reverse `init`: clear nudges, stop the daemon, restore the saved
# pane-border-format, drop our options, and remove ONLY our focus hooks.
cmd_uninstall() {
  # 1) Clear every active nudge (restores per-pane / per-window overrides).
  local p st
  while read -r p st; do
    if [ -n "${st:-}" ]; then cmd_off -t "$p"; fi
  done < <(tmux list-panes -a -F '#{pane_id} #{@nudge_state}' 2>/dev/null)

  # 2) Stop the daemon.
  local pid; pid="$(daemon_pid)"
  [ -n "$pid" ] && kill "$pid" 2>/dev/null || true
  tmux set -gu @nudge_daemon_pid 2>/dev/null || true

  # 3) Restore the user's original pane-border-format.
  local saved; saved="$(tmux show -gv @nudge_saved_pbf 2>/dev/null || true)"
  if [ -n "$saved" ]; then tmux set -g pane-border-format "$saved"
  else tmux set -gu pane-border-format 2>/dev/null || true; fi

  # 4) Drop our global options.
  tmux set -gu @nudge_phase 2>/dev/null || true
  tmux set -gu @nudge_saved_pbf 2>/dev/null || true

  # 5) Remove ONLY our select-pane/window hooks (matched by our path), by index
  #    high->low so earlier indices stay valid; the user's own hooks survive.
  local name
  for name in after-select-pane after-select-window; do
    tmux show-hooks -g 2>/dev/null | grep -F "$SELF" \
      | grep -oE "^${name}\[[0-9]+\]" | grep -oE '[0-9]+' | sort -rn \
      | while read -r idx; do tmux set-hook -gu "${name}[$idx]" 2>/dev/null || true; done || true
  done

  tmux refresh-client 2>/dev/null || true
  echo "tmux-nudge uninstalled."
}

# Universal harness adapter. ANY AI tool (Claude Code, Codex, Kiro CLI, …) that
# can run a command on a lifecycle event registers this. It resolves the agent's
# pane from $TMUX_PANE and maps a nudge state; any extra args (a JSON payload the
# harness appends, e.g. Codex) are ignored. Must NEVER exit non-zero — a Claude
# `Stop` hook exiting 2 would block Claude from stopping.
#
#   nudge hook <needs-input|done|error|clear> [-t pane] [ignored...]
cmd_hook() {
  local state="${1:-}"; shift 2>/dev/null || true
  local pane="${TMUX_PANE:-}"
  while [ $# -gt 0 ]; do case "$1" in -t) pane="$2"; shift 2 ;; *) shift ;; esac; done
  [ -n "$pane" ] || exit 0
  case "$state" in
    needs-input|done|error) cmd_on  -t "$pane" -s "$state" >/dev/null 2>&1 || true ;;
    clear|off)              cmd_off -t "$pane"             >/dev/null 2>&1 || true ;;
  esac
  exit 0
}

# Print a ready-to-paste Claude Code hooks block for ~/.claude/settings.json.
cmd_claude_config() {
  cat <<JSON
{
  "hooks": {
    "Stop": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "$SELF hook needs-input" } ] }
    ],
    "Notification": [
      { "matcher": "permission_prompt|idle_prompt", "hooks": [ { "type": "command", "command": "$SELF hook needs-input" } ] }
    ],
    "UserPromptSubmit": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "$SELF hook clear" } ] }
    ]
  }
}
JSON
}

# Print a ready-to-paste Codex notify line for ~/.codex/config.toml. Codex only
# emits agent-turn-complete today, so it maps to "needs-input" (your turn); the
# nudge clears when you focus the pane. Codex appends the event JSON as an extra
# arg, which `nudge hook` ignores.
cmd_codex_config() {
  cat <<TOML
# ~/.codex/config.toml
notify = ["$SELF", "hook", "needs-input"]
TOML
}

# Print a ready-to-paste hooks block for a Kiro CLI agent configuration file.
# Kiro fires `stop` when the agent finishes a turn (→ needs-input) and
# `userPromptSubmit` when you reply (→ clear); it sends the event JSON on stdin,
# which `nudge hook` ignores.
cmd_kiro_config() {
  cat <<JSON
{
  "hooks": {
    "stop": [
      { "command": "$SELF hook needs-input" }
    ],
    "userPromptSubmit": [
      { "command": "$SELF hook clear" }
    ]
  }
}
JSON
}

# Print the line to add to ~/.zshrc or ~/.bashrc to enable the generic
# "long command finished" trigger for any shell command.
cmd_shell_init() {
  echo "source $(dirname "$(dirname "$SELF")")/shell/nudge.sh"
}

main() {
  local cmd="${1:-help}"; shift 2>/dev/null || true
  case "$cmd" in
    init)          cmd_init "$@" ;;
    on)            cmd_on "$@" ;;
    off)           cmd_off "$@" ;;
    daemon)        cmd_daemon "$@" ;;
    ensure-daemon) ensure_daemon ;;
    status)        cmd_status "$@" ;;
    hook)          cmd_hook "$@" ;;
    uninstall)     cmd_uninstall ;;
    claude-config) cmd_claude_config ;;
    codex-config)  cmd_codex_config ;;
    kiro-config)   cmd_kiro_config ;;
    shell-init)    cmd_shell_init ;;
    *) echo "usage: nudge {init | uninstall | on [-t pane] [-s state] [--if-away] | off [-t pane] | hook <state> | daemon [-i sec] | status | claude-config | codex-config | kiro-config | shell-init}" ;;
  esac
}
main "$@"
