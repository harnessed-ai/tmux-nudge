#!/usr/bin/env bash
#
# nudge-claude — Claude Code hook adapter for tmux-nudge.
#
# Registered on Claude Code's Stop / Notification / UserPromptSubmit events.
# Learns the agent's pane from $TMUX_PANE (inherited by hooks) and drives the
# `nudge` engine accordingly.
#
#   Stop / Notification(permission_prompt|idle_prompt)  ->  nudge-claude needs-input
#   UserPromptSubmit                                    ->  nudge-claude clear
#
# IMPORTANT: this must NEVER exit non-zero — a Stop hook exiting 2 would block
# Claude from stopping. So: no `set -e`, everything guarded, always exit 0.

action="${1:-}"
pane="${TMUX_PANE:-}"

# Not running inside tmux (or pane unknown) -> nothing to do, succeed quietly.
[ -n "$pane" ] || exit 0

NUDGE="$(cd "$(dirname "$0")" 2>/dev/null && pwd)/nudge"
[ -x "$NUDGE" ] || exit 0

case "$action" in
  needs-input|done|error) "$NUDGE" on  -t "$pane" -s "$action" >/dev/null 2>&1 || true ;;
  clear|off)              "$NUDGE" off -t "$pane"              >/dev/null 2>&1 || true ;;
esac

exit 0
